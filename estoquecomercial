SELECT * FROM itens_estoque
WHERE setor_item = (
    SELECT setor_item 
    FROM itens_estoque
    WHERE setor_item IN ('bebidas')
);

SELECT descricao_item
FROM itens_estoque
WHERE id_item IN (
SELECT id_item
FROM itens_estoque
WHERE id_item > 2
);

SELECT I.descricao_item,
(
SELECT SUM(P.quantidadeComprada * P.valorTotal)
FROM Pedidos AS P
WHERE P.idItem = I.idItem
)
AS Total_Comprado
FROM itens_estoque AS I;

SELECT SUM(quantidadeComprada * valorTotal)
FROM Pedidos;
