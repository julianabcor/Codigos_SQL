CREATE TABLE Pedidos (
    idPedido INT AUTO_INCREMENT,
    idItem INT,
    quantidadeComprada INT,
    valorTotal DECIMAL(9, 2),
    dataPedido DATE,
    PRIMARY KEY (idPedido)
);

