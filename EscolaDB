-- 1
select * from Alunos;

-- 2
select nome 
from Alunos;

-- 3
select nome_curso
from Cursos;

-- 4
select nome 
from Alunos
where cidade = 'São Paulo';

-- 5
select nome 
from Alunos
where idade > 20;

-- 6
select nome_curso as CURSO 
from Cursos
where carga_horaria > 50;

-- 7
select nome 
from Alunos
where idade >= 18 and idade <= 22;

-- 8
select nome 
from Alunos 
where cidade = 'Curitiba';

-- 9
select nome 
from Alunos 
where idade < 21;

-- 10
select id_matricula 
from Matriculas;

-- 11
select A.nome, M.nota
from Alunos as A
join Matriculas as M on A.id_aluno = M.id_aluno
where M.nota > 8;

-- 12
select A.nome, M.faltas
from Alunos as A
join Matriculas as M on A.id_aluno = M.id_aluno
where M.faltas > 5;

-- 13
select nome_curso, carga_horaria 
from Cursos
where carga_horaria = 80;

-- 14
select nome 
from Alunos 
where cidade != 'São Paulo';

-- 15
select nome 
from Alunos 
where nome like 'A%';

-- 16
select nome 
from Alunos 
where nome like '%a';

-- 17
select nome_curso 
from Cursos 
where nome_curso like '%Dados%';

-- 18
select id_matricula, nota 
from Matriculas
where nota >=7 and nota <= 9;

-- 19
select nome 
from Alunos 
where idade = 20;

-- 20
select nome_curso, carga_horaria 
from Cursos
where carga_horaria <= 60;

-- 21
select count(nome), cidade
from Alunos
group by cidade;

-- 22
select avg(idade) as media_de_idade, cidade 
from Alunos 
group by cidade;

-- 23
select count(M.id_matricula), C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso;

-- 24
select AVG(M.nota) as media, C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso;

-- 25
select sum(M.faltas), C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso;

-- 26
select max(M.nota), C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso;

-- 27
select min(M.nota), C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso;

-- 28
select sum(M.faltas) as soma_total, A.nome
from Matriculas as M
join Alunos as A on M.id_aluno = A.id_aluno
group by nome;

-- 29
select avg(M.nota) as media, A.nome
from Matriculas as M
join Alunos as A on M.id_aluno = A.id_aluno
group by nome;

-- 30
select count(nome), idade as faixa_etatia 
from Alunos
group by idade;

-- 31
select count(id_aluno) as Alunos, cidade 
from Alunos
group by cidade
having count(id_aluno) > 2;

-- 32
select avg(M.nota) as media_notas, C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso
having avg(M.nota) > 8;

-- 33
select count(M.id_matricula), C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso
having count(M.id_matricula) > 2;

-- 34
select A.nome as Alunos, sum(M.faltas) as total
from Alunos as A
join Matriculas as M on A.id_aluno = M.id_aluno
group by A.nome
having total > 5;

-- 35
select min(M.nota) as notas, A.nome
from Matriculas as M
join Alunos as A on M.id_aluno = A.id_aluno
group by nome
having min(M.nota) > 6;

-- 36
select nome_curso, carga_horaria 
from Cursos
order by carga_horaria desc;

-- 37
select nome, idade 
from Alunos
order by idade desc;

-- 38
select avg(M.nota) as media_notas, C.nome_curso
from Matriculas as M
join Cursos as C on M.id_curso = C.id_curso
group by nome_curso
order by media_notas desc;

-- 39
select cidade, count(nome) as quant_alunos 
from Alunos
group by cidade
order by count(nome) asc;

-- 40
select avg(M.nota) as media, A.nome
from Matriculas as M
join Alunos as A on M.id_aluno = A.id_aluno
group by nome
having media > 7
order by media desc;

